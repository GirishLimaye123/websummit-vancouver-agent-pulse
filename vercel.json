{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/AI-pulse",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/AI-pulse/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/AI-pulse",
      "destination": "/"
    },
    {
      "source": "/AI-pulse/:path*",
      "destination": "/:path*"
    }
  ]
}
